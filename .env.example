# KnowMind 基础配置
HOST=0.0.0.0
PORT=8000

# 模型配置，Day 05 接入真实模型时填写
ARK_API_KEY=
MODEL=
FAST_MODEL=
BASE_URL=
CHAT_TIMEOUT_SECONDS=60

# 数据库和缓存，Day 06 以后启用
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/knowmind
REDIS_URL=redis://127.0.0.1:6379/0

# 鉴权配置，Day 07 以后启用
JWT_SECRET_KEY=please-change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
ADMIN_INVITE_CODE=knowmind-admin

# Milvus 和检索配置，Day 13 以后启用
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=knowmind_embeddings
DENSE_EMBEDDING_DIM=1024
BM25_STATE_PATH=data/bm25_state.json
